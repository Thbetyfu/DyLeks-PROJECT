# DyLeks Backend — Environment Variables
# Salin file ini menjadi '.env' dan isi nilai yang diperlukan

# === AI Engine Config ===
# Konfigurasi Database (Opsional, untuk fitur tracking offline nanti)
DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=dyleks_db

# Konfigurasi AI Lokal (100% Offline)
# Base URL Ollama (default: http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434

# Model untuk Teacher's Copilot (Text/Chat)
OLLAMA_MODEL=qwen2:1.5b

# Model untuk Vision Screening (Image Analysis)
# Rekomendasi: moondream (ringan, ~1.7GB) atau llava-phi3 (~3.8GB)
OLLAMA_VISION_MODEL=moondream

# === HuggingFace Config (TrOCR Fallback) ===

# Opsional - hanya diperlukan jika model TrOCR dikunci
HF_TOKEN=

# === Database Config ===
# Path ke file SQLite lokal
DATABASE_URL=sqlite:///./dyslexiai_local.db
